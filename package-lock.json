{
  "name": "postr",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "postr",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/api": {
      "name": "@postr/api",
      "version": "0.0.0"
    },
    "apps/web": {
      "name": "@postr/web",
      "version": "0.0.0"
    },
    "node_modules/@postr/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@postr/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@postr/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/shared": {
      "name": "@postr/shared",
      "version": "0.0.0"
    }
  }
}
