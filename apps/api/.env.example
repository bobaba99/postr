# Postr API — environment variables
#
# Copy to `.env` and fill in values. None of these are exposed to the
# browser; keep the secret keys out of source control.

# Port the Express server listens on. Render sets this automatically
# in prod; only override in dev.
PORT=8787

# Comma-separated list of allowed origins for CORS. Must include the
# dev origin AND every production origin you serve the frontend from.
# Example:
#   dev:  http://localhost:5173
#   prod: https://postr.sh,https://www.postr.sh
# No trailing slashes, no spaces.
CORS_ORIGINS=http://localhost:5173

# ── Supabase (server-side) ────────────────────────────────────────
# Project URL — same as VITE_SUPABASE_URL on the web app.
SUPABASE_URL=

# Service / secret key — NEVER expose this to the browser. Used by
# the API for admin operations (create-user, send-email, etc.). Store
# as an encrypted env var in Render.
SUPABASE_SECRET_KEY=

# ── LLM provider ──────────────────────────────────────────────────
# Anthropic API key for the scan-poster endpoint. Usage is rate-limited
# per-user via the middleware stack.
ANTHROPIC_API_KEY=

# ── Cron endpoints ────────────────────────────────────────────────
# Shared secret used by scheduled jobs (e.g. anonymous user cleanup).
# Generate a random 32-byte hex string: `openssl rand -hex 32`.
# GitHub Actions calls these endpoints with `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=
