# Postr web app — environment variables
#
# Copy to `.env` and fill in values. Vite only exposes variables that
# start with `VITE_` to the browser, so every name below is deliberate.
# Never add secrets here — anything you put in a VITE_ var ships to
# every visitor's browser.

# ── Supabase (browser client) ─────────────────────────────────────
# Project URL — e.g. https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Publishable (anon) key — NOT the service_role / secret key.
# Safe to expose; RLS policies are what actually protect the data.
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Backend API ────────────────────────────────────────────────────
# Base URL of the Express API (apps/api). Dev: http://localhost:8787
# Prod: https://api.postr.sh (or whatever Render hostname you pick).
# No trailing slash.
VITE_API_BASE_URL=
